APP_HOST=0.0.0.0
APP_PORT=4002
APP_RELOAD=false
LOG_LEVEL=INFO
LOG_REQUEST_BODIES=false
REQUEST_LOG_BODY_MAX_BYTES=256
HTTP_TIMEOUT_SECONDS=10
WEBHOOK_MAX_ATTEMPTS=2
WEBHOOK_RETRY_DELAY_SECONDS=1
SERVICE_URL=http://127.0.0.1:4002
PAYMENTS_SERVICE_URL=http://127.0.0.1:4001

# Provider fidelity. Defaults are strict (contract-faithful).
# Set to false to opt back into permissive mode for early-stage local development.
STRICT_PROVIDER_AUTH=true
STRICT_PROVIDER_VALIDATION=true
RELAXED_WAAS_KYC=false
MOCK_CALLBACK_DELAY_SECONDS=0

# Optional provider credentials. When set, Basic-auth/credential checks are enforced.
SASAPAY_CLIENT_ID=
SASAPAY_CLIENT_SECRET=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SECURITY_CREDENTIAL=
MPESA_INITIATOR_NAME=

# Database. dbmate reads DATABASE_URL directly (mysql://user:pass@host:port/db).
# The app uses DATABASE_URL if set, else assembles from the DB_* variables below.
DATABASE_URL=mysql://root:root@127.0.0.1:3306/pgw_mock
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=pgw_mock
DB_CONNECTION_LIMIT=10

# dbmate
DBMATE_MIGRATIONS_DIR=./db/migrations
DBMATE_SCHEMA_FILE=./db/schema.sql
DBMATE_NO_DUMP_SCHEMA=true
