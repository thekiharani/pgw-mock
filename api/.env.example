APP_HOST=0.0.0.0
APP_PORT=4200
APP_RELOAD=false
LOG_LEVEL=INFO
LOG_REQUEST_BODIES=false
REQUEST_LOG_BODY_MAX_BYTES=256
HTTP_TIMEOUT_SECONDS=10
WEBHOOK_MAX_ATTEMPTS=2
WEBHOOK_RETRY_DELAY_SECONDS=1
SERVICE_URL=http://127.0.0.1:4200
PAYMENTS_SERVICE_URL=http://127.0.0.1:4001

STRICT_PROVIDER_AUTH=true
STRICT_PROVIDER_VALIDATION=true
RELAXED_WAAS_KYC=false
MOCK_CALLBACK_DELAY_SECONDS=0

MPESA_PASSKEY=
MPESA_SECURITY_CREDENTIAL=
MPESA_INITIATOR_NAME=

# --- Dashboard static serving (prod) ---
# When true, Fastify serves the compiled dashboard (dashboard/dist) and falls
# back to index.html for client routes. Leave false in dev (Vite serves on :3200).
SERVE_DASHBOARD=false
DASHBOARD_DIST=./public

# --- Dashboard auth (BetterAuth) ---
# Generate a strong secret: `openssl rand -base64 32`
AUTH_SECRET=dev-insecure-secret-change-me
# Browser-facing origin of the auth endpoints. In dev this is the dashboard
# (Vite) origin, which proxies /api to this server; in prod it is the public origin.
AUTH_BASE_URL=http://localhost:3200
AUTH_TRUSTED_ORIGINS=http://localhost:3200
# Google OAuth (Cloud Console). Redirect URI: <AUTH_BASE_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (OTP delivery) ---
# Driver: smtp (local, e.g. Mailpit) | resend (prod) | ses (future) | console (logs OTP)
MAIL_DRIVER=smtp
MAIL_FROM=Noria Payments Mock <no-reply@noria.local>
# SMTP (defaults target a local Mailpit on 127.0.0.1:1025)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
# Resend (set MAIL_DRIVER=resend to use)
RESEND_API_KEY=

DATABASE_URL=mysql://root:root@127.0.0.1:3306/pgw_mock
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=pgw_mock
DB_CONNECTION_LIMIT=10

DBMATE_MIGRATIONS_DIR=./db/migrations
DBMATE_SCHEMA_FILE=./db/schema.sql
DBMATE_NO_DUMP_SCHEMA=true
