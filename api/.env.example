APP_HOST=0.0.0.0
APP_PORT=4200
APP_RELOAD=false
LOG_LEVEL=INFO
LOG_REQUEST_BODIES=false
REQUEST_LOG_BODY_MAX_BYTES=256
HTTP_TIMEOUT_SECONDS=10
WEBHOOK_MAX_ATTEMPTS=2
WEBHOOK_RETRY_DELAY_SECONDS=1
SERVICE_URL=http://127.0.0.1:4200

STRICT_PROVIDER_AUTH=true
STRICT_PROVIDER_VALIDATION=true
RELAXED_WAAS_KYC=false
MOCK_CALLBACK_DELAY_SECONDS=0

MPESA_PASSKEY=
MPESA_SECURITY_CREDENTIAL=
MPESA_INITIATOR_NAME=

SERVE_DASHBOARD=false
DASHBOARD_DIST=./public

AUTH_SECRET=dev-insecure-secret-change-me
AUTH_BASE_URL=http://localhost:3200
AUTH_TRUSTED_ORIGINS=http://localhost:3200
DASHBOARD_URL=http://localhost:3200
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MAIL_DRIVER=smtp
MAIL_FROM=Noria Payments Mock <no-reply@noria.local>
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
RESEND_API_KEY=

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/pgw_mock
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pgw_mock
DB_CONNECTION_LIMIT=10

DBMATE_MIGRATIONS_DIR=./db/migrations
DBMATE_SCHEMA_FILE=./db/schema.sql
DBMATE_NO_DUMP_SCHEMA=true
